# Copy to .env and fill in. Loaded by supervisor.py via python-dotenv.

# Which LLM provider the Supervisor uses. One of: openai | groq | xai
LLM_PROVIDER=openai

# Model name. Provider-specific; the adapter passes this through unchanged.
# Examples: gpt-4o-mini  |  llama-3.3-70b-versatile  |  grok-2-latest
LLM_MODEL=gpt-4o-mini

# Provide the key for whichever provider you selected above.
OPENAI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=

# Set to 1 in CI / local to opt into integration tests that hit a real Docker Swarm.
# DOCKER_SWARM_TESTS=1
